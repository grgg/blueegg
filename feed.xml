---
sitemap: false
---
<?xml version="1.0" encoding="utf-8"?>
<feed xmlns="http://www.w3.org/2005/Atom" xml:lang="{{ site.lang | default: 'en' }}">
  <generator uri="https://jekyllrb.com/">Jekyll</generator>
  <link href="{{ '/feed.xml' | absolute_url }}" rel="self" type="application/atom+xml" />
  <link href="{{ '/' | absolute_url }}" rel="alternate" type="text/html" hreflang="{{ site.lang | default: 'en' }}" />
  <updated>{{ site.time | date_to_xmlschema }}</updated>
  <id>{{ '/feed.xml' | absolute_url }}</id>
  <title type="html">{{ site.title | xml_escape }}</title>
  <subtitle>{{ site.description | xml_escape }}</subtitle>
  <author><name>Blue Egg</name></author>
  {% for post in site.posts %}
  {%- assign cover = post.art | prepend: '/assets/images/releases/' | absolute_url -%}
  <entry>
    <title type="html">{{ post.title | xml_escape }}</title>
    <link href="{{ post.url | absolute_url }}" rel="alternate" type="text/html" title="{{ post.title | xml_escape }}" />
    <published>{{ post.date | date_to_xmlschema }}</published>
    <updated>{{ post.date | date_to_xmlschema }}</updated>
    <id>{{ post.url | absolute_url | xml_escape }}</id>
    <author><name>Blue Egg</name></author>
    {% if post.tag %}<category term="{{ post.tag | xml_escape }}" />{% endif %}{% if post.type %}<category term="{{ post.type | xml_escape }}" />{% endif %}
    <summary type="html">{{ post.excerpt | strip_html | normalize_whitespace | xml_escape }}</summary>
    <content type="html" xml:base="{{ post.url | absolute_url }}"><![CDATA[
<p><img src="{{ cover }}" alt="{{ post.title }} cover art" width="600" /></p>
<p>{{ post.excerpt | strip_html | normalize_whitespace }}</p>
<p><strong>Listen:</strong>
{% assign sep = false -%}
{% if post.bandcamp %}{% if sep %} &middot; {% endif %}<a href="{{ post.bandcamp }}">Bandcamp</a>{% assign sep = true %}{% endif %}
{% if post.apple %}{% if sep %} &middot; {% endif %}<a href="{{ post.apple }}">Apple Music</a>{% assign sep = true %}{% endif %}
{% if post.spotify %}{% if sep %} &middot; {% endif %}<a href="{{ post.spotify }}">Spotify</a>{% assign sep = true %}{% endif %}
{% if post.youtube %}{% if sep %} &middot; {% endif %}<a href="{{ post.youtube }}">YouTube Music</a>{% assign sep = true %}{% endif %}
{% if post.soundcloud %}{% if sep %} &middot; {% endif %}<a href="{{ post.soundcloud }}">SoundCloud</a>{% assign sep = true %}{% endif %}
{% if post.amazon %}{% if sep %} &middot; {% endif %}<a href="{{ post.amazon }}">Amazon Music</a>{% assign sep = true %}{% endif %}
{% if post.pandora %}{% if sep %} &middot; {% endif %}<a href="{{ post.pandora }}">Pandora</a>{% assign sep = true %}{% endif %}
{% if post.tidal %}{% if sep %} &middot; {% endif %}<a href="{{ post.tidal }}">Tidal</a>{% assign sep = true %}{% endif %}
{% if post.iheart %}{% if sep %} &middot; {% endif %}<a href="{{ post.iheart }}">iHeartRadio</a>{% assign sep = true %}{% endif %}
{% if post.deezer %}{% if sep %} &middot; {% endif %}<a href="{{ post.deezer }}">Deezer</a>{% assign sep = true %}{% endif %}
</p>
<p><a href="{{ post.url | absolute_url }}">Open the release page &rarr;</a></p>
    ]]></content>
  </entry>
  {% endfor %}
</feed>
