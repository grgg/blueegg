source "https://rubygems.org"

# Use the github-pages gem so the local build matches what GitHub Pages runs
# (it pins Jekyll and the allowed plugins to the exact versions Pages uses).
gem "github-pages", group: :jekyll_plugins

# Plugins (also bundled by github-pages, listed here for clarity).
group :jekyll_plugins do
  gem "jekyll-feed"
  gem "jekyll-sitemap"
end

# Windows / JRuby timezone data (harmless elsewhere).
gem "tzinfo-data", platforms: [:mingw, :mswin, :x64_mingw, :jruby]
